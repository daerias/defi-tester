                                                                    <div
                                                                        class="cookie-description">Das Cookie wird eingesetzt um den Cache für unterschiedliche Szenarien und Seitenbenutzer zu differenzieren.</div>
                                                                </div>

                                                                                                                                                                                                                                                                </div>
